# JobLeak Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# FIREBASE CONFIGURATION (Required)
# ============================================
# Get these from Firebase Console > Project Settings > General
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
VITE_FIREBASE_DATABASE_ID=(default)

# ============================================
# SUPABASE (Optional - for lead storage)
# ============================================
# Get these from Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================
# ANALYTICS (Recommended for production)
# ============================================
# Google Analytics 4
# Get from https://analytics.google.com > Admin > Data Streams
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Mixpanel
# Get from https://mixpanel.com > Project Settings
VITE_MIXPANEL_TOKEN=your_mixpanel_token_here

# Enable/Disable Analytics
VITE_ANALYTICS_ENABLED=true
VITE_ANALYTICS_DEBUG=false

# ============================================
# EXTERNAL APIs (Optional)
# ============================================
# Municipal Permit Data API
VITE_PERMIT_API_URL=https://your-permit-api.com/v1

# SAM.gov API for Federal Bids
VITE_SAM_API_KEY=your_sam_gov_api_key

# Google Places API for Local Competitors
VITE_GOOGLE_PLACES_API_KEY=your_google_places_api_key

# ============================================
# DEVELOPMENT OPTIONS
# ============================================
# Disable HMR (Hot Module Replacement) if needed
DISABLE_HMR=false
