# JobLeak Environment Variables

# GEMINI_API_KEY: Required for Gemini AI API calls (if applicable)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Platform backend ingress URL
APP_URL="MY_APP_URL"

# SUPABASE INTELLIGENCE DATA PERSISTENCE
VITE_SUPABASE_URL="https://your-supabase-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# OPTIONAL CONFIGURABLE INTEGRATION API LAYERS
VITE_PERMIT_API_URL=""
VITE_SAM_API_KEY=""
VITE_GOOGLE_PLACES_API_KEY=""

# PRODUCTION STRIPE PAYMENT INTEGRATION SECRETS (Optional for Live Billing)
STRIPE_SECRET_KEY="sk_test_..."
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."

